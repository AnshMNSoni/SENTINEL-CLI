/// Prisma schema for the Sentinel database.
///
/// Mirrors Nightcode's `packages/database/prisma/schema.prisma` (which has
/// only a `Session` model) with the additions needed by Sentinel's
/// security/chat platform.
///
/// Usage:
///   bunx prisma generate
///   bunx prisma migrate dev
///
/// Or, for environments without Prisma, the SQLite/JSON adapter in
/// `adapter.js` provides a drop-in replacement with the same surface.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  title       String
  mode        String   @default("BUILD")
  model       String   @default("claude-sonnet-4-6")
  projectPath String?
  messages    Json     @default("[]")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model CreditEvent {
  id        String   @id @default(cuid())
  userId    String
  sessionId String?
  credits   Int
  provider  String?
  model     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
}

model UserPreferences {
  userId      String   @id
  theme       String?
  defaultMode String   @default("BUILD")
  defaultModel String  @default("claude-sonnet-4-6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
